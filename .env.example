# ============================================================
# CRM Armando Paredes — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA comitas .env al repositorio.
# ============================================================

# Base de datos PostgreSQL (Railway lo genera automáticamente)
DATABASE_URL="postgresql://user:password@host:5432/crm_ap"

# JWT — cambia el secret en producción (mín. 32 caracteres aleatorios)
JWT_SECRET="cambia-esto-por-algo-largo-y-aleatorio-en-produccion"
JWT_EXPIRES_IN="12h"

# Webhook (n8n / Urbania)
WEBHOOK_SECRET="otro-secreto-largo-para-webhooks"

# Entorno
NODE_ENV="production"
PORT=3000
